class predicates
    отец:(name, name) nondeterm anyflow.
    мать:(name, name) nondeterm anyflow.
    брат:(name, name) nondeterm anyflow.
    сестра:(name, name) nondeterm anyflow.
    дед:(name, name) nondeterm anyflow.


clauses

отец(Отец, Ребенок):-
    мужчина(Отец),
    родитель(Отец, Ребенок).

мать(Мать, Ребенок):-
    женщина(Мать),
    родитель(Мать, Ребенок).

брат(Брат, Родственник):-
    мужчина(Брат),
    родитель(Родитель, Брат),
    родитель(Родитель, Родственник),
    Брат <> Родственник.

сестра(Сестра, Родственник):-
    женщина(Сестра),
    родитель(Родитель, Сестра),
    родитель(Родитель, Родственник),
    Сестра <> Родственник.

дед(Дед, Внук):-
    мужчина(Дед),
    родитель(Дед, Родитель),
    родитель(Родитель, Внук).


clauses

    run():-
        nl,
        write("Отцы и их дети:"), nl,
        отец(Отец, Ребенок),
        write(Отец, " - отец ", Ребенок), nl,
        fail.

    run():-
        nl,
        write("Сестры:"), nl,
        сестра(Сестра, Родственник),
        write(Сестра, " - сестра ", Родственник), nl,
        fail.

    run():-
        nl,
        write("Деды и внуки:"), nl,
        дед(Дед, Внук),
        write(Дед, " - дед ", Внук), nl,
        fail.

    run().

end implement main

goal
    console::runUtf8(main::run).