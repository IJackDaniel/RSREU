родитель("Сергей", "Андрей").
родитель("Татьяна", "Андрей").

% Семья Екатерины и Николая — 1 ребёнок
родитель("Николай", "Наталья").
родитель("Екатерина", "Наталья").


class predicates
    отец:(name, name) nondeterm anyflow.
    мать:(name, name) nondeterm anyflow.
    брат:(name, name) nondeterm anyflow.
    сестра:(name, name) nondeterm anyflow.
    дед:(name, name) nondeterm anyflow.
    количество_детей:(name, integer) nondeterm anyflow.
    семья_с_одним_ребенком:(name, name) nondeterm anyflow.
    семья_с_двумя_детьми:(name, name) nondeterm anyflow.


clauses

отец(Отец, Ребенок):-
    мужчина(Отец),
    родитель(Отец, Ребенок).

мать(Мать, Ребенок):-
    женщина(Мать),
    родитель(Мать, Ребенок).

брат(Брат, Родственник):-
    мужчина(Брат),
    родитель(Родитель, Брат),
    родитель(Родитель, Родственник),
    Брат <> Родственник.

сестра(Сестра, Родственник):-
    женщина(Сестра),
    родитель(Родитель, Сестра),
    родитель(Родитель, Родственник),
    Сестра <> Родственник.

дед(Дед, Внук):-
    мужчина(Дед),
    родитель(Дед, Родитель),
    родитель(Родитель, Внук).

количество_детей(Родитель, Количество):-
    Количество = list::length([Ребенок || родитель(Родитель, Ребенок)]).

семья_с_одним_ребенком(Родитель1, Родитель2):-
    родитель(Родитель1, Ребенок),
    родитель(Родитель2, Ребенок),
    Родитель1 <> Родитель2,
    количество_детей(Родитель1, 1),
    количество_детей(Родитель2, 1).

семья_с_двумя_детьми(Родитель1, Родитель2):-
    родитель(Родитель1, Ребенок),
    родитель(Родитель2, Ребенок),
    Родитель1 <> Родитель2,
    количество_детей(Родитель1, 2),
    количество_детей(Родитель2, 2).


clauses

    run():-
        nl,
        write("Отцы и их дети:"), nl,
        отец(Отец, Ребенок),
        write(Отец, " - отец ", Ребенок), nl,
        fail.

    run():-
        nl,
        write("Сестры:"), nl,
        сестра(Сестра, Родственник),
        write(Сестра, " - сестра ", Родственник), nl,
        fail.

    run():-
        nl,
        write("Деды и внуки:"), nl,
        дед(Дед, Внук),
        write(Дед, " - дед ", Внук), nl,
        fail.

    run():-
        nl,
        write("Количество детей у каждого родителя:"), nl,
        родитель(Родитель, _),
        количество_детей(Родитель, Количество),
        write(Родитель, " имеет ", Количество, " детей"), nl,
        fail.

    run():-
        nl,
        write("Семьи с одним ребенком:"), nl,
        семья_с_одним_ребенком(Родитель1, Родитель2),
        write(Родитель1, " и ", Родитель2, " имеют ровно одного ребенка"), nl,
        fail.

    run():-
        nl,
        write("Семьи с двумя детьми:"), nl,
        семья_с_двумя_детьми(Родитель1, Родитель2),
        write(Родитель1, " и ", Родитель2, " имеют ровно двух детей"), nl,
        fail.

    run().

end implement main

goal
    console::runUtf8(main::run).